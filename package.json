{
  "name": "bulutlar",
  "version": "2.2.0",
  "description": "",
  "main": "public/electron.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "start-react": "vite",
    "build-react": "vite build",
    "start-electron": "electron .",
    "sleep2s": "node -e \"setTimeout(() => process.exit(0), 2000)\"",
    "dev": "concurrently \"npm run start-react\" \"npm run sleep2s && npm run start-electron\"",
    "verify:blt-shape-b": "node scripts/verify-shape-b-blt.mjs",
    "verify:archiver-utf8": "node scripts/verify-archiver-utf8-flag.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild-native": "node scripts/rebuild-sqlite3.mjs",
    "postinstall": "node scripts/rebuild-sqlite3.mjs && node scripts/copy-bundled-fonts.mjs",
    "copy-fonts": "node scripts/copy-bundled-fonts.mjs",
    "package-mac": "npm run build-react && electron-builder --mac",
    "package-mac-builder": "npm run build-react && electron-builder --mac",
    "package-mac-builder-universal": "npm run build-react && electron-builder --mac --universal",
    "package-mac-builder-arm64": "npm run build-react && electron-builder --mac --arm64",
    "package-mac-builder-x64": "npm run build-react && electron-builder --mac --x64",
    "package-win": "npm run build-react && electron-builder --win --x64",
    "package-linux": "npm run build-react && electron-builder --linux",
    "migrate": "npx sequelize-cli db:migrate",
    "dist": "npm run build-react && electron-builder",
    "postinstall2": "node postInstall.js",
    "prepare-release-notes": "node scripts/prepare-release-notes.mjs",
    "ensure-github-release-notes": "dotenv -- node scripts/ensure-github-release-notes.mjs",
    "publish-mac-universal": "npm run build-react && npm run prepare-release-notes && dotenv -- electron-builder --mac --universal --publish always && npm run ensure-github-release-notes",
    "publish-only-mac": "npm run prepare-release-notes && dotenv -- node scripts/publish-dist-only.mjs mac && npm run ensure-github-release-notes",
    "publish-win": "npm run build-react && npm run prepare-release-notes && dotenv -- electron-builder --win --publish always && npm run ensure-github-release-notes",
    "publish-only-win": "npm run prepare-release-notes && dotenv -- node scripts/publish-dist-only.mjs win && npm run ensure-github-release-notes"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "depcheck": "^1.4.7",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/audiowide": "^5.2.7",
    "@fontsource/bitter": "^5.2.10",
    "@fontsource/cardo": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/crimson-text": "^5.2.7",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/electrolize": "^5.2.8",
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/libre-baskerville": "^5.2.10",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-serif": "^5.2.9",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/old-standard-tt": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/pt-serif": "^5.2.8",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/saira": "^5.2.11",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@fontsource/spectral": "^5.2.8",
    "@heroicons/react": "^2.1.5",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-highlight": "3.26.0",
    "@tiptap/extension-placeholder": "3.26.0",
    "@tiptap/extension-subscript": "3.26.0",
    "@tiptap/extension-superscript": "3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/react": "3.26.0",
    "@tiptap/starter-kit": "3.26.0",
    "archiver": "^7.0.1",
    "date-fns": "^3.6.0",
    "docx": "^9.5.1",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.2.0",
    "hijri-date": "^0.2.2",
    "html-react-parser": "^5.0.11",
    "html-to-text": "^9.0.5",
    "i18next": "^23.16.0",
    "image-size": "^2.0.2",
    "immutable": "^5.1.3",
    "jsdom": "^27.0.0",
    "jszip": "^3.10.1",
    "lodash.debounce": "^4.0.8",
    "path-browserify": "^1.0.1",
    "pdfkit": "^0.17.2",
    "react": "^19.2.0",
    "react-datepicker": "^7.5.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.0.3",
    "react-modal": "^3.16.1",
    "react-resizable-panels": "^4.7.2",
    "react-select": "^5.8.1",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "toastr": "^2.1.4",
    "umzug": "^3.8.2",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "nth-check": "^2.0.1",
    "@tiptap/core": "3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/react": "3.26.0",
    "ajv": "^8.18.0",
    "@develar/schema-utils": {
      "ajv": "^6.12.6"
    },
    "dmg-license": {
      "ajv": "^6.12.6"
    },
    "tar": "^7.5.16",
    "@tootallnate/once": "^2.0.1",
    "sequelize": {
      "uuid": "^11.1.1"
    }
  },
  "build": {
    "appId": "com.kargilabs.bulutlar",
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    },
    "publish": {
      "provider": "github",
      "owner": "trxrg",
      "repo": "bulutlar"
    },
    "fileAssociations": [
      {
        "ext": "blt",
        "name": "Bulutlar Archive",
        "description": "Bulutlar shareable archive bundle",
        "mimeType": "application/vnd.bulutlar.sync+zip",
        "role": "Editor",
        "rank": "Owner"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*",
      "**/*.{node,dll,dylib,so}",
      "public/fonts/**/*"
    ],
    "compression": "store",
    "files": [
      "build/**/*",
      "backend/**/*",
      "public/**/*",
      "scripts/font-catalog.mjs",
      "postInstall.js",
      "package.json",
      "CHANGELOG.md",
      "!**/node_modules/@fontsource/**"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "installerIcon": "public/cloud.ico"
    },
    "win": {
      "icon": "public/cloud.ico",
      "forceCodeSigning": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "public/cloud.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "asar": true,
      "compression": "maximum",
      "extendInfo": {
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.kargilabs.bulutlar.blt",
            "UTTypeDescription": "Bulutlar Archive",
            "UTTypeConformsTo": [
              "public.data",
              "public.archive"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "blt"
              ],
              "public.mime-type": [
                "application/vnd.bulutlar.sync+zip"
              ]
            }
          }
        ]
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "assets/icons/png/1024x1024.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
