{
  "name": "bulutlar",
  "version": "2.1.0",
  "description": "",
  "main": "public/electron.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "start-react": "react-scripts start",
    "build-react": "react-scripts build",
    "start-electron": "electron .",
    "sleep2s": "node -e \"setTimeout(() => process.exit(0), 2000)\"",
    "dev": "concurrently \"npm run start-react\" \"npm run sleep2s && npm run start-electron\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "rebuild-native": "electron-rebuild -f -w sqlite3",
    "package-mac": "npm run build-react && electron-builder --mac",
    "package-mac-builder": "npm run build-react && electron-builder --mac",
    "package-mac-builder-universal": "npm run build-react && electron-builder --mac --universal",
    "package-mac-builder-arm64": "npm run build-react && electron-builder --mac --arm64",
    "package-mac-builder-x64": "npm run build-react && electron-builder --mac --x64",
    "package-win": "npm run build-react && electron-builder --win --x64",
    "package-linux": "npm run build-react && electron-builder --linux",
    "migrate": "npx sequelize-cli db:migrate",
    "dist": "npm run build-react && electron-builder",
    "postinstall2": "node postInstall.js",
    "publish-mac-universal": "npm run build-react && dotenv -- electron-builder --mac --universal --publish always",
    "publish-win": "npm run build-react && dotenv -- electron-builder --win --publish always"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!(@tiptap|prosemirror-))"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@electron/rebuild": "^4.0.3",
    "concurrently": "^8.2.2",
    "depcheck": "^1.4.7",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@heroicons/react": "^2.1.5",
    "@mui/icons-material": "^5.15.4",
    "@mui/material": "^5.16.13",
    "@tiptap/extension-highlight": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/extension-subscript": "^3.22.1",
    "@tiptap/extension-superscript": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "archiver": "^7.0.1",
    "date-fns": "^3.6.0",
    "docx": "^9.5.1",
    "draft-js": "^0.11.7",
    "draft-js-export-html": "^1.4.1",
    "draft-js-import-html": "^1.4.1",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.2.0",
    "hijri-date": "^0.2.2",
    "html-react-parser": "^5.0.11",
    "html-to-text": "^9.0.5",
    "i18next": "^23.16.0",
    "image-size": "^2.0.2",
    "immutable": "^5.1.3",
    "jsdom": "^27.0.0",
    "lodash.debounce": "^4.0.8",
    "path-browserify": "^1.0.1",
    "pdfkit": "^0.17.2",
    "react": "^18.2.0",
    "react-datepicker": "^7.5.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.0.3",
    "react-modal": "^3.16.1",
    "react-resizable-panels": "^4.7.2",
    "react-scripts": "^5.0.1",
    "react-select": "^5.8.1",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "toastr": "^2.1.4",
    "umzug": "^3.8.2",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "create-dmg": "^7.0.0"
  },
  "overrides": {
    "nth-check": "^2.0.1"
  },
  "build": {
    "appId": "com.kargilabs.bulutlar",
    "publish": {
      "provider": "github",
      "owner": "trxrg",
      "repo": "bulutlar"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*",
      "**/*.{node,dll,dylib,so}"
    ],
    "compression": "store",
    "files": [
      "build/**/*",
      "backend/**/*",
      "public/**/*",
      "postInstall.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "installerIcon": "public/cloud.ico"
    },
    "win": {
      "icon": "public/cloud.ico",
      "forceCodeSigning": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "public/cloud.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "asar": true,
      "compression": "maximum"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "assets/icons/png/1024x1024.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
